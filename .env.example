# ==========================================
# SwarmAlpha Environment Configuration
# ==========================================
# Copy this file to '.env' and fill in the values. 
# DO NOT commit the actual '.env' file to version control.

# --- System Settings ---
ENVIRONMENT=paper_trading       # Options: backtest, paper_trading, live
LOG_LEVEL=INFO                  # Options: DEBUG, INFO, WARNING, ERROR

# --- LLM Provider Keys (Cognitive Engines) ---
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# --- Market Data & Execution Brokers ---
# Alpaca (Equities - Retail/Paper)
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Interactive Brokers (Institutional)
IB_GATEWAY_HOST=127.0.0.1
IB_GATEWAY_PORT=4002
IB_CLIENT_ID=1

# --- Infrastructure & Databases ---
# Redis (In-Memory State)
REDIS_URL=redis://localhost:6379/0

# Apache Kafka (Message Broker)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# TimescaleDB (Time-Series Market Data)
TIMESCALEDB_URL=postgresql://quant_user:secure_password@localhost:5432/market_data

# Pinecone (Vector DB for Document Analysis/Private Credit)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=gcp-starter

# --- Engineering Plane (Factory) ---
# E2B Sandbox for safe code execution (Auditor/Developer Agents)
E2B_API_KEY=your_e2b_api_key
